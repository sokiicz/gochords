{
  "name": "gochords",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run sitemap && tsc -b && vite build && npm run prerender",
    "sitemap": "tsx scripts/generate-sitemap.ts",
    "prerender": "tsx scripts/prerender.ts",
    "preview": "vite preview",
    "audit": "tsx scripts/audit-chords.ts",
    "audit:legacy-capo": "tsx scripts/audit-legacy-capo.ts",
    "build:pwa-icons": "tsx scripts/build-pwa-icons.ts",
    "build:og": "tsx scripts/build-og-image.ts",
    "test": "tsx scripts/test-parser.ts && tsx scripts/test-transpose.ts && tsx scripts/test-search.ts && tsx scripts/test-profile.ts",
    "backfill:languages": "tsx scripts/backfill-languages.ts",
    "fix:italian-tags": "tsx scripts/fix-italian-tags.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.105.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "sharp": "^0.34.5",
    "tsx": "^4.21.0",
    "typescript": "^5.6.3",
    "vite": "^6.0.3"
  }
